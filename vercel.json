{
  "installCommand": "cd reactbits-prototype && npm ci",
  "buildCommand": "cd reactbits-prototype && npm run build",
  "outputDirectory": "reactbits-prototype/dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
