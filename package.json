{
  "name": "screen-time-manager",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:playwright": "playwright test",
    "firefox:prepare": "node tools/prepare-firefox-package.mjs",
    "firefox:lint": "npm run firefox:prepare && npx --yes web-ext lint --source-dir dist/firefox",
    "firefox:build": "npm run firefox:prepare && npx --yes web-ext build --source-dir dist/firefox --artifacts-dir output/firefox --overwrite-dest",
    "website:dev": "npm --prefix website run dev",
    "website:build": "npm --prefix website run build",
    "website:preview": "npm --prefix website run preview",
    "prune:production-builds": "node tools/prune-production-builds.mjs",
    "export:ga4": "node tools/ga4-data-api-export.mjs",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "jest": "^29.7.0",
    "sharp": "^0.35.3",
    "wrangler": "^4.95.0"
  }
}
