{
    "manifest_version": 3,
    "name": "Screen Time Manager - Website Blocker and Focus Tool",
    "version": "2.2.12",
    "description": "Understand browsing habits, limit distracting sites, and stay focused with daily limits and scheduled blocks.",
    "icons": {
        "16": "new_logo.png",
        "32": "new_logo.png",
        "48": "new_logo.png",
        "128": "new_logo.png"
    },
    "action": {
        "default_title": "Screen Time Manager",
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["http://*/*", "https://*/*"],
            "js": ["activity-heartbeat.js"],
            "run_at": "document_idle"
        }
    ],
    "permissions": ["storage", "tabs", "alarms", "notifications", "declarativeNetRequest"],
    "externally_connectable": {
        "matches": ["https://screen-time-manager.jackster0627.workers.dev/*"]
    },
    "host_permissions": ["<all_urls>"],
    "web_accessible_resources": [
        {
            "resources": ["blocked.html", "blocked.js", "blocked.css", "assets/icons/icon.png"],
            "matches": ["<all_urls>"]
        },
        {
            "resources": ["popup.html", "popup.js", "popup.css"],
            "matches": ["https://screen-time-manager.jackster0627.workers.dev/*"]
        }
    ]
}
